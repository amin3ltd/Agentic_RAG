# Environment variables for Agentic RAG Pipeline
# Copy this file to .env and fill in your values

# ============================================
# Ollama Configuration (Local LLM - Recommended)
# ============================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3

# ============================================
# Firecrawl API Key (Optional - for web search)
# ============================================
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# ============================================
# OpenAI API Key (Fallback - if Ollama not available)
# ============================================
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Specify model (defaults to qwen3 for Ollama)
# OPENAI_MODEL_NAME=gpt-4
